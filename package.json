{
  "name": "pixel-compressor",
  "version": "1.0.4",
  "author": "Moebytes",
  "description": "A cute image compressor!",
  "main": "dist/main/index.js",
  "scripts": {
    "start": "npm run clean && rsbuild build && npm run copy && npm run gif-copy && electron dist/main/index.js",
    "build": "npm run clean ./build && rsbuild build && npm run copy && electron-builder -p never",
    "rebuild": "electron-rebuild -f -w @napi-rs/canvas",
    "gif-copy": "mkdir dist/vendor && cp vendor/gifsicle.app dist/vendor/gifsicle",
    "copy": "node copy.ts",
    "patch": "node patch.ts",
    "clean": "del-cli ./dist"
  },
  "overrides": {
    "graceful-fs": "^4.2.11"
  },
  "keywords": [
    "image",
    "compressor",
    "resizer",
    "renamer",
    "anime"
  ],
  "repository": "https://github.com/Moebytes/Pixel-Compressor",
  "privacyPolicy": "https://moebytes.com/privacy-policy",
  "license": "CC BY-NC 4.0",
  "build": {
    "appId": "com.moebytes.pixel-compressor",
    "productName": "Pixel Compressor",
    "directories": {
      "buildResources": "assets",
      "output": "build"
    },
    "buildDependenciesFromSource": true,
    "electronLanguages": ["en"],
    "mac": {
      "icon": "assets/mas/icon.icns",
      "target": {
        "target": "mas",
        "arch": "arm64"
      },
      "type": "distribution",
      "provisioningProfile": "assets/mas/MacAppStore.provisionprofile",
      "category": "public.app-category.utilities",
      "extraResources": [
        {
          "from": "vendor/gifsicle.app",
          "to": "app.asar.unpacked/dist/vendor/gifsicle"
        }
      ]
    },
    "mas": {
      "entitlements": "assets/mas/entitlements.mas.plist",
      "entitlementsInherit": "assets/mas/entitlements.mas.inherit.plist"
    },
    "dmg": {
      "title": "${productName}",
      "background": "./assets/background.png",
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "win": {
      "icon": "assets/appx/icon.ico",
      "target": {
        "target": "appx",
        "arch": "x64"
      },
      "extraResources": [
        {
          "from": "vendor/gifsicle.exe",
          "to": "app.asar.unpacked/dist/vendor/gifsicle.exe"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "uninstallDisplayName": "Pixel Compressor",
      "createDesktopShortcut": "always",
      "installerSidebar": "./assets/installer.bmp",
      "uninstallerSidebar": "./assets/installer.bmp"
    },
    "appx": {
      "identityName": "Moebytes.PixelCompressor",
      "publisher": "CN=4C1B763B-CF01-4978-8749-986F562173D8",
      "publisherDisplayName": "Moebytes",
      "capabilities": [
          "runFullTrust"
      ]
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": {
        "target": "appImage",
        "arch": "x64"
      },
      "category": "Utility",
      "extraResources": [
        {
          "from": "vendor/gifsicle",
          "to": "app.asar.unpacked/dist/vendor/gifsicle"
        }
      ]
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "**/*.node"
    ]
  },
  "devDependencies": {
    "@electron-rsbuild/plugin-main": "^0.0.12",
    "@electron-rsbuild/plugin-preload": "^0.0.12",
    "@electron-rsbuild/plugin-renderer": "^0.0.12",
    "@electron/rebuild": "^4.0.3",
    "@rsbuild/core": "^1.7.3",
    "@rsbuild/plugin-less": "^1.6.0",
    "@rsbuild/plugin-node-polyfill": "^1.4.4",
    "@rsbuild/plugin-react": "^1.4.5",
    "@rsbuild/plugin-type-check": "^1.3.3",
    "@svgr/webpack": "^8.1.0",
    "@types/electron-localshortcut": "^3.1.3",
    "@types/gif-encoder": "^0.7.4",
    "@types/imagemin": "^9.0.1",
    "@types/imagemin-gifsicle": "^7.0.4",
    "@types/imagemin-mozjpeg": "^8.0.4",
    "@types/imagemin-optipng": "^5.2.4",
    "@types/imagemin-webp": "^7.0.3",
    "@types/pdf-image": "^2.0.4",
    "@types/pdfkit": "^0.17.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sharp": "^0.32.0",
    "cross-env": "^10.1.0",
    "del-cli": "^7.0.0",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "node-addon-api": "^8.5.0",
    "node-gyp": "^12.2.0",
    "transform-loader": "^0.2.4",
    "typescript": "^5.9.3",
    "wasm-loader": "^1.3.0",
    "worker-loader": "^3.0.8"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.93",
    "@react-pdf/pdfkit": "^4.1.0",
    "@reduxjs/toolkit": "^2.11.2",
    "ass-to-srt": "^1.2.1",
    "ass-to-vtt": "^1.2.0",
    "bing-translate-api": "^4.2.0",
    "bootstrap": "^5.3.8",
    "browser-id3-writer": "^6.3.1",
    "electron-click-drag-plugin": "^2.0.2",
    "electron-localshortcut": "^3.2.1",
    "electron-store": "^8.0.0",
    "gif-encoder": "^0.7.2",
    "gif-frames": "github:Moestash/gif-frames#no-cumulative",
    "image-pixels": "^2.2.2",
    "image-size": "^2.0.2",
    "imagemin": "^8.0.1",
    "imagemin-gifsicle": "^7.0.0",
    "imagemin-mozjpeg": "^9.0.0",
    "imagemin-pngquant": "^9.0.2",
    "imagemin-webp": "^6.0.0",
    "images-meta": "github:Moestash/images-meta",
    "mkv-subtitle-extractor": "^1.1.1",
    "pdfjs-dist": "github:Moestash/pdfjs-dist",
    "rc-slider": "^11.1.9",
    "react": "^19.2.4",
    "react-bootstrap": "^2.10.10",
    "react-compare-slider": "^3.1.0",
    "react-dom": "^19.2.4",
    "react-redux": "^9.2.0",
    "react-sortablejs": "^6.1.4",
    "react-zoom-pan-pinch": "^3.7.0",
    "sagiri": "^4.3.0",
    "shade-blend-color": "^1.0.0",
    "sharp": "^0.34.5",
    "sharp-phash": "^2.2.0",
    "srt-to-vtt": "^1.1.3"
  }
}
